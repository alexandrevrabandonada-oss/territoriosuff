{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; frame-ancestors 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://*.ingest.sentry.io; frame-src 'self' https://www.instagram.com https://*.supabase.co; worker-src 'self' blob:; manifest-src 'self'; media-src 'self' blob: https:"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(sw.js|registerSW.js|manifest.webmanifest|robots.txt|sitemap.xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/s/acervo/:slug",
      "destination": "/api/share/acervo?slug=:slug"
    },
    {
      "source": "/s/blog/:slug",
      "destination": "/api/share/blog?slug=:slug"
    },
    {
      "source": "/s/relatorios/:slug",
      "destination": "/api/share/relatorios?slug=:slug"
    },
    {
      "source": "/s/boletim/:ym",
      "destination": "/api/share/boletim?ym=:ym"
    },
    {
      "source": "/s/dossies/:slug",
      "destination": "/api/share/dossies?slug=:slug"
    },
    {
      "source": "/s/agenda/:id",
      "destination": "/api/share/agenda?eventId=:id"
    },
    {
      "source": "/s/dados/:code",
      "destination": "/api/share/dados?station_code=:code"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|@|src/|node_modules/|assets/|data/|reports/|favicon\\.ico|manifest\\.webmanifest|registerSW\\.js|sw\\.js|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
