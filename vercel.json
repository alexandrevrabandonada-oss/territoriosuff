{
  "rewrites": [
    {
      "source": "/s/acervo/:slug",
      "destination": "/api/share/acervo?slug=:slug"
    },
    {
      "source": "/s/blog/:slug",
      "destination": "/api/share/blog?slug=:slug"
    },
    {
      "source": "/s/relatorios/:slug",
      "destination": "/api/share/relatorios?slug=:slug"
    },
    {
      "source": "/s/boletim/:ym",
      "destination": "/api/share/boletim?ym=:ym"
    },
    {
      "source": "/s/dossies/:slug",
      "destination": "/api/share/dossies?slug=:slug"
    },
    {
      "source": "/s/agenda/:id",
      "destination": "/api/share/agenda?eventId=:id"
    },
    {
      "source": "/s/dados/:code",
      "destination": "/api/share/dados?station_code=:code"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|@|src/|node_modules/|assets/|data/|favicon\\.ico|manifest\\.webmanifest|registerSW\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
