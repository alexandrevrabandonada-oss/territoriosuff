    "@types/node": "^25.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/web": "^0.0.339",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.11.1",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.6.0",
    "lighthouse": "^13.0.3",
    "postcss": "^8.5.6",
