{
  "name": "semear-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run build",
    "db:push": "node tools/db-push-safe.mjs",
    "db:status": "npx supabase db status",
    "db:types:local": "npx supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:types:remote": "source .env.local 2>/dev/null || true; npx supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/lib/supabase/database.types.ts",
    "db:doctor": "node tools/migration-doctor.mjs",
    "db:sync": "node tools/migration-sync.mjs",
    "env:doctor": "node tools/env-doctor.mjs",
    "env:clean": "node tools/env-clean.mjs",
    "fn:deploy": "npx supabase functions deploy --no-verify-jwt",
    "secrets:set": "node tools/secrets-set.mjs",
    "ship:infra": "npm run db:push && npm run fn:deploy && npm run done",
    "ship:content": "npm run acervo:import && npm run collections:import && npm run blog:import && npm run reports:import && npm run transparency:import && npm run done",
    "ship:all": "npm run ship:infra && npm run ship:content",
    "simulate:sensor": "node tools/simulate-sensor.mjs",
    "simulate:sensor:retry": "node tools/simulate-sensor.mjs --retry",
    "smoke": "node tools/db-smoke.mjs && node tools/route-smoke.mjs",
    "test:smoke:ui": "playwright test --grep @smoke",
    "test:a11y": "playwright test --grep @a11y",
    "snapshot": "node tools/snapshot.mjs",
    "audit:lighthouse": "node tools/lighthouse-audit.mjs",
    "acervo:import": "node tools/acervo-import.mjs",
    "acervo:upload": "node tools/acervo-upload.mjs",
    "blog:import": "node tools/blog-import.mjs",
    "collections:import": "node tools/collections-import.mjs",
    "transparency:import": "node tools/transparency-import.mjs",
    "demo:dados": "node tools/demo-measurements.mjs",
    "demo:load": "node tools/demo-load.mjs",
    "done": "npm run verify && npm run smoke && npm run db:doctor && npm run db:sync && npm run env:doctor && npm run snapshot",
    "reports:import": "node tools/reports-import.mjs",
    "reports:upload": "node tools/reports-upload.mjs",
    "db:normalize": "node tools/migrations-normalize.mjs",
    "ship:reports": "npm run reports:import && npm run done",
    "transparency:upload": "node tools/transparency-upload.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/og": "^0.11.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.8.2",
    "tailwindcss": "^3.4.17",
    "uplot": "^1.6.32",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/web": "^0.0.339",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.11.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "lighthouse": "^13.0.3",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
