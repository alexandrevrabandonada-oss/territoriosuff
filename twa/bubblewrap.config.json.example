{
  "host": "www.semearsf.org",
  "name": "SEMEAR",
  "launcherName": "SEMEAR",
  "display": "standalone",
  "themeColor": "#18A572",
  "backgroundColor": "#0A1F1A",
  "startUrl": "/",
  "iconUrl": "https://www.semearsf.org/icons/icon-512x512.png",
  "maskableIconUrl": "https://www.semearsf.org/icons/icon-maskable-512x512.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "./android.keystore",
    "alias": "semear-key"
  },
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "shortcuts": [
    {
      "name": "Dados",
      "short_name": "Dados",
      "url": "/dados",
      "icon": "https://www.semearsf.org/icons/icon-192x192.png"
    },
    {
      "name": "Acervo",
      "short_name": "Acervo",
      "url": "/acervo",
      "icon": "https://www.semearsf.org/icons/icon-192x192.png"
    }
  ],
  "packageId": "br.org.semear.pwa",
  "webManifestUrl": "https://www.semearsf.org/manifest.webmanifest",
  "fallbackType": "customtabs",
  "features": {
    "locationDelegation": {
      "enabled": false
    },
    "playBilling": {
      "enabled": false
    }
  },
  "alphaDependencies": {
    "enabled": false
  },
  "enableNotifications": true
}
